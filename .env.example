# OpenAI
OPENAI_API_KEY=your_openai_api_key
OPENAI_MODEL=gpt-4o-mini
WHISPER_API_URL=https://api.openai.com/v1/audio/transcriptions

# Toss Payments
TOSS_PAYMENTS_SECRET_KEY=your_toss_secret_key
TOSS_PAYMENTS_CLIENT_KEY=your_toss_client_key

# Google OAuth2 / Calendar
GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret
GOOGLE_REDIRECT_URI=http://localhost:8083/login/oauth2/code/google

# Database
MYSQL_URL=jdbc:mysql://localhost:3306/momatic?useSSL=false&serverTimezone=UTC&characterEncoding=utf8
MYSQL_USERNAME=momatic_user
MYSQL_PASSWORD=your_mysql_password