    {
      "name": "Meetings",
      "item": [
        {
          "name": "List Meetings",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/meetings?page=0&size=10",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "meetings"
              ],
              "query": [
                {
                  "key": "page",
                  "value": "0"
                },
                {
                  "key": "size",
                  "value": "10"
                }
              ]
            },
            "description": "현재 Mock 인증 사용자가 소유한 회의 목록 페이지를 조회합니다."
          },
          "response": []
        },
        {
          "name": "Get Meeting Detail",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/meetings/{{meetingId}}",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "meetings",
                "{{meetingId}}"
              ]
            },
            "description": "현재 Mock 인증 사용자가 소유한 회의 상세 페이지를 조회합니다."
          },
          "response": []
        },
        {
          "name": "Get Meeting Upload Page",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/meetings/upload",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "meetings",
                "upload"
              ]
            },
            "description": "회의 음성 파일 업로드 페이지를 조회합니다."
          },
          "response": []
        },
        {
          "name": "Get Meeting Status",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/meetings/{{meetingId}}/status",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "meetings",
                "{{meetingId}}",
                "status"
              ]
            },
            "description": "현재 Mock 인증 사용자가 소유한 회의의 처리 상태를 조회합니다."
          },
          "response": []
        },
        {
          "name": "Upload Meeting File",
          "request": {
            "method": "POST",
            "header": [],
            "body": {
              "mode": "formdata",
              "formdata": [
                {
                  "key": "userId",
                  "value": "{{userId}}",
                  "type": "text"
                },
                {
                  "key": "teamId",
                  "value": "{{teamId}}",
                  "type": "text"
                },
                {
                  "key": "title",
                  "value": "주간 회의",
                  "type": "text"
                },
                {
                  "key": "file",
                  "type": "file",
                  "src": []
                }
              ]
            },
            "url": {
              "raw": "{{baseUrl}}/meetings/upload",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "meetings",
                "upload"
              ]
            },
            "description": "회의 음성 파일을 form-data 형식으로 업로드합니다. Postman에서 file 필드에 업로드할 파일을 선택하세요."
          },
          "response": []
        }
      ]
    },
    {
      "name": "Action Items",
      "item": [
        {
          "name": "Update Action Item Status",
          "request": {
            "method": "PATCH",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json",
                "type": "text"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"status\": \"IN_PROGRESS\"\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            },
            "url": {
              "raw": "{{baseUrl}}/action-items/{{actionItemId}}/status",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "action-items",
                "{{actionItemId}}",
                "status"
              ]
            },
            "description": "현재 Mock 인증 사용자가 소유한 회의의 액션 아이템 상태를 변경합니다. status에는 TODO, IN_PROGRESS, DONE 중 하나를 입력할 수 있습니다."
          },
          "response": []
        }
      ]
    },
    {
      "name": "Payments",
      "item": [
        {
          "name": "Get Payment History",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/payments?page=0&size=10",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "payments"
              ],
              "query": [
                {
                  "key": "page",
                  "value": "0"
                },
                {
                  "key": "size",
                  "value": "10"
                }
              ]
            },
            "description": "현재 Mock 인증 사용자의 결제 내역 페이지를 조회합니다."
          },
          "response": []
        },
        {
          "name": "Checkout Payment",
          "request": {
            "method": "POST",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/payments/checkout",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "payments",
                "checkout"
              ]
            },
            "description": "선택한 요금제의 결제창 호출 페이지를 생성합니다.",
            "body": {
              "mode": "urlencoded",
              "urlencoded": [
                {
                  "key": "planType",
                  "value": "PRO",
                  "type": "text"
                }
              ]
            }
          },
          "response": []
        },
        {
          "name": "Confirm Payment",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json",
                "type": "text"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/payments/confirm",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "payments",
                "confirm"
              ]
            },
            "description": "결제 승인 요청을 처리합니다.",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"orderId\": \"{{orderId}}\",\n  \"paymentKey\": \"{{paymentKey}}\",\n  \"amount\": 19900\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            }
          },
          "response": []
        },
        {
          "name": "Complete Payment Redirect",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/payments/success?paymentKey={{paymentKey}}&orderId={{orderId}}&amount=19900",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "payments",
                "success"
              ],
              "query": [
                {
                  "key": "paymentKey",
                  "value": "{{paymentKey}}"
                },
                {
                  "key": "orderId",
                  "value": "{{orderId}}"
                },
                {
                  "key": "amount",
                  "value": "19900"
                }
              ]
            },
            "description": "토스페이먼츠 결제 성공 리다이렉트를 처리합니다."
          },
          "response": []
        },
        {
          "name": "Get Payment Failure Page",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/payments/fail?code=PAYMENT_FAILED&message=결제에 실패했습니다.",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "payments",
                "fail"
              ],
              "query": [
                {
                  "key": "code",
                  "value": "PAYMENT_FAILED"
                },
                {
                  "key": "message",
                  "value": "결제에 실패했습니다."
                }
              ]
            },
            "description": "토스페이먼츠 결제 실패 페이지를 조회합니다."
          },
          "response": []
        },
        {
          "name": "Handle Payment Webhook",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json",
                "type": "text"
              },
              {
                "key": "Authorization",
                "value": "Basic {{tossWebhookAuthorization}}",
                "type": "text"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/payments/webhook",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "payments",
                "webhook"
              ]
            },
            "description": "토스페이먼츠 Webhook 이벤트를 처리합니다. Authorization 값은 실행 환경에 맞게 입력하세요.",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"eventType\": \"PAYMENT_DONE\",\n  \"data\": {\n    \"orderId\": \"{{orderId}}\",\n    \"paymentKey\": \"{{paymentKey}}\"\n  }\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            }
          },
          "response": []
        }
      ]
    }
  ],
